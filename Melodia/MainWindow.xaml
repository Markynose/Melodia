<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Melodia.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Melodia prelude">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Drag region / title bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0">
            <!-- App name (left) -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="16,0,0,0" Spacing="10">
                <FontIcon Glyph="&#xE8D6;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="18" />
                <TextBlock Text="Melodia"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Version tag (right, clear of caption buttons) -->
            <Button HorizontalAlignment="Right"
                    Margin="0,0,148,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4,0"
                    VerticalAlignment="Center">
                <Button.Flyout>
                    <Flyout Placement="Bottom">
                        <TextBlock Text="version 0.1.0 aka prelude"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </Flyout>
                </Button.Flyout>
                <TextBlock Text="prelude"
                           FontSize="11"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center" />
            </Button>
        </Grid>

        <!-- All player UI lives in MainPage -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
