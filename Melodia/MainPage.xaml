<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Melodia.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:Melodia.Helpers"
    xmlns:models="using:Melodia.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Space" Invoked="KeyShortcut_PlayPause" />
        <KeyboardAccelerator Key="Right" Modifiers="Control" Invoked="KeyShortcut_Next" />
        <KeyboardAccelerator Key="Left"  Modifiers="Control" Invoked="KeyShortcut_Previous" />
    </Page.KeyboardAccelerators>

    <Page.Resources>
        <helpers:SecondsToTimeConverter x:Key="SecondsToTime" />
    </Page.Resources>

    <Grid x:Name="RootGrid" AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*"   MinWidth="280" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: Library ════════════════════════════════════════════════ -->
        <Grid x:Name="LibraryPanel" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Click="OpenFolder_Click"
                    HorizontalAlignment="Stretch"
                    Margin="8,10,8,4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xED43;"
                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              FontSize="16" />
                    <TextBlock Text="Open Folder" />
                </StackPanel>
            </Button>

            <TextBox Grid.Row="1"
                     x:Name="SearchBox"
                     PlaceholderText="Search…"
                     Text="{x:Bind ViewModel.FilterText, Mode=TwoWay}"
                     Margin="8,0,8,4" />

            <Grid Grid.Row="2" Margin="8,2,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{x:Bind ViewModel.SongCountText, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />

                <ComboBox Grid.Column="1"
                          x:Name="SortComboBox"
                          SelectionChanged="Sort_SelectionChanged"
                          MinWidth="80"
                          FontSize="11"
                          Padding="6,3,24,3">
                    <ComboBoxItem Content="Default" IsSelected="True" />
                    <ComboBoxItem Content="Title" />
                    <ComboBoxItem Content="Artist" />
                    <ComboBoxItem Content="Album" />
                    <ComboBoxItem Content="Duration" />
                </ComboBox>
            </Grid>

            <ListView Grid.Row="3"
                      x:Name="SongListView"
                      ItemsSource="{x:Bind ViewModel.FilteredSongs, Mode=OneWay}"
                      DoubleTapped="SongListView_DoubleTapped"
                      RightTapped="SongListView_RightTapped"
                      SelectionMode="Single"
                      Padding="0,0,0,12">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:SongItem">
                        <Grid Padding="4,5,8,5" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="1">
                                <TextBlock Text="{x:Bind DisplayTitle}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1"
                                           FontSize="13" />
                                <TextBlock Text="{x:Bind DisplayArtist}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind DurationString}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Divider -->
        <Grid x:Name="LeftDivider" Grid.Column="1"
              Background="Transparent"
              PointerEntered="Divider_PointerEntered"
              PointerExited="Divider_PointerExited"
              PointerPressed="LeftDivider_PointerPressed"
              PointerMoved="LeftDivider_PointerMoved"
              PointerReleased="Divider_PointerReleased">
            <Rectangle Width="1" HorizontalAlignment="Center"
                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
        </Grid>

        <!-- ═══ MIDDLE: Now playing ══════════════════════════════════════════ -->
        <ScrollViewer x:Name="NowPlayingScroller"
                      Grid.Column="2"
                      SizeChanged="NowPlayingScroller_SizeChanged"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <!-- NowPlayingGrid.MinHeight is kept = scroller height in code-behind so
                 the StackPanel centers when content is short and scrolls when lyrics overflow -->
            <Grid x:Name="NowPlayingGrid">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="480"
                        Padding="32,16,32,40"
                        Spacing="0">

                <!-- Album art -->
                <Border Width="200" Height="200"
                        CornerRadius="12"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid>
                        <FontIcon Glyph="&#xE8D6;"
                                  FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                  FontSize="64"
                                  Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                  Visibility="{x:Bind ViewModel.PlaceholderVisibility, Mode=OneWay}" />
                        <Image Source="{x:Bind ViewModel.AlbumArt, Mode=OneWay}"
                               Stretch="UniformToFill"
                               Visibility="{x:Bind ViewModel.AlbumArtVisibility, Mode=OneWay}" />
                    </Grid>
                </Border>

                <!-- Title -->
                <TextBlock Text="{x:Bind ViewModel.NowPlayingTitle, Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="2" />

                <!-- Artist · Album -->
                <TextBlock Text="{x:Bind ViewModel.NowPlayingSubtitle, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"
                           Margin="0,4,0,0" />

                <!-- Seek bar -->
                <Grid Margin="0,24,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Slider Grid.Row="0"
                            Minimum="0"
                            Maximum="{x:Bind ViewModel.Duration, Mode=OneWay}"
                            Value="{x:Bind ViewModel.Position, Mode=TwoWay}"
                            HorizontalAlignment="Stretch"
                            StepFrequency="1"
                            ThumbToolTipValueConverter="{StaticResource SecondsToTime}" />

                    <Grid Grid.Row="1" Margin="4,-4,4,0">
                        <TextBlock HorizontalAlignment="Left"
                                   Text="{x:Bind ViewModel.Position, Converter={StaticResource SecondsToTime}, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Text="{x:Bind ViewModel.Duration, Converter={StaticResource SecondsToTime}, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </Grid>

                <!-- Transport controls + Volume -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="4"
                                VerticalAlignment="Center">

                        <Button Click="Shuffle_Click"
                                Width="40" Height="40"
                                Opacity="{x:Bind ViewModel.ShuffleOpacity, Mode=OneWay}"
                                ToolTipService.ToolTip="Shuffle">
                            <FontIcon Glyph="&#xE8B1;"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="20" />
                        </Button>

                        <Button Click="Previous_Click"
                                Width="40" Height="40"
                                ToolTipService.ToolTip="Previous">
                            <FontIcon Glyph="&#xE892;"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="18" />
                        </Button>

                        <Button Click="PlayPause_Click"
                                Width="52" Height="52"
                                Style="{StaticResource AccentButtonStyle}"
                                ToolTipService.ToolTip="Play / Pause">
                            <FontIcon Glyph="{x:Bind ViewModel.PlayPauseGlyph, Mode=OneWay}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="20" />
                        </Button>

                        <Button Click="Next_Click"
                                Width="40" Height="40"
                                ToolTipService.ToolTip="Next">
                            <FontIcon Glyph="&#xE893;"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="18" />
                        </Button>

                        <Button Click="Repeat_Click"
                                Width="40" Height="40"
                                Opacity="{x:Bind ViewModel.RepeatOpacity, Mode=OneWay}"
                                ToolTipService.ToolTip="Repeat">
                            <FontIcon Glyph="{x:Bind ViewModel.RepeatGlyph, Mode=OneWay}"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="20" />
                        </Button>
                    </StackPanel>

                    <!-- Volume -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="6">
                        <FontIcon Glyph="&#xE767;"
                                  FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                  FontSize="16"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Slider Minimum="0" Maximum="1"
                                Value="{x:Bind ViewModel.Volume, Mode=TwoWay}"
                                Width="88"
                                StepFrequency="0.01"
                                VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- ── Lyrics ─────────────────────────────────────────────── -->
                <StackPanel Visibility="{x:Bind ViewModel.LyricsVisibility, Mode=OneWay}"
                            Margin="0,32,0,0">

                    <TextBlock Text="LYRICS"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               CharacterSpacing="100"
                               Margin="0,0,0,12" />

                    <Grid>
                        <ListView x:Name="LyricsListView"
                                  ItemsSource="{x:Bind ViewModel.Lyrics, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="LyricLine_Click"
                                  ContainerContentChanging="LyricsListView_ContainerContentChanging"
                                  MaxHeight="280"
                                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                  ScrollViewer.IsVerticalScrollChainingEnabled="False">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="Padding"   Value="8,6" />
                                    <Setter Property="MinHeight" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:LyricLine">
                                    <TextBlock Text="{x:Bind Text}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               FontSize="15"
                                               Opacity="0.4"
                                               RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform ScaleX="0.85" ScaleY="0.85" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button x:Name="SnapToCurrentButton"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,8"
                                Width="32" Height="32"
                                Padding="0"
                                CornerRadius="16"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="SnapToCurrent_Click"
                                ToolTipService.ToolTip="Jump to current lyric">
                            <FontIcon Glyph="&#xE8B4;"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="13" />
                        </Button>
                    </Grid>
                </StackPanel>

            </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- View layout button — overlaid in center column, top-right corner -->
        <Button Grid.Column="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="32" Height="32"
                Margin="0,4,4,0"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                ToolTipService.ToolTip="View options">
            <Button.Flyout>
                <MenuFlyout Placement="BottomEdgeAlignedRight">
                    <ToggleMenuFlyoutItem x:Name="LibraryToggle"
                                         Text="Library"
                                         IsChecked="True"
                                         Click="ToggleLibrary_Click" />
                    <ToggleMenuFlyoutItem x:Name="PlaylistToggle"
                                         Text="Playlist"
                                         IsChecked="True"
                                         Click="TogglePlaylist_Click" />
                    <MenuFlyoutSeparator />
                    <ToggleMenuFlyoutItem x:Name="SwapToggle"
                                         Text="Swap panels"
                                         IsChecked="False"
                                         Click="SwapPanels_Click" />
                </MenuFlyout>
            </Button.Flyout>
            <FontIcon Glyph="&#xE8A9;"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      FontSize="14" />
        </Button>

        <!-- Divider -->
        <Grid x:Name="RightDivider" Grid.Column="3"
              Background="Transparent"
              PointerEntered="Divider_PointerEntered"
              PointerExited="Divider_PointerExited"
              PointerPressed="RightDivider_PointerPressed"
              PointerMoved="RightDivider_PointerMoved"
              PointerReleased="Divider_PointerReleased">
            <Rectangle Width="1" HorizontalAlignment="Center"
                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
        </Grid>

        <!-- ═══ RIGHT: Playlist ═════════════════════════════════════════════ -->
        <Grid x:Name="PlaylistPanel" Grid.Column="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="8,10,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                    <TextBlock Text="PLAYLIST"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               CharacterSpacing="100" />
                    <TextBlock Text="{x:Bind ViewModel.PlaylistCountText, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Click="JumpToCurrent_Click"
                        Width="32" Height="32"
                        ToolTipService.ToolTip="Jump to playing song">
                    <FontIcon Glyph="&#xE8B4;"
                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              FontSize="13" />
                </Button>
            </Grid>

            <!-- Playlist -->
            <ListView Grid.Row="1"
                      x:Name="PlaylistView"
                      ItemsSource="{x:Bind ViewModel.Playlist}"
                      SelectionChanged="PlaylistView_SelectionChanged"
                      RightTapped="PlaylistView_RightTapped"
                      DragItemsCompleted="PlaylistView_DragItemsCompleted"
                      SelectionMode="Single"
                      CanReorderItems="True"
                      CanDragItems="True"
                      AllowDrop="True"
                      Padding="0,0,0,12">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:SongItem">
                        <Grid Padding="4,5,8,5" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="1">
                                <TextBlock Text="{x:Bind DisplayTitle}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1"
                                           FontSize="13" />
                                <TextBlock Text="{x:Bind DisplayArtist}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind DurationString}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

    </Grid>
</Page>
